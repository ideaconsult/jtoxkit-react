{
  "name": "@ideaconsult/jtoxkit-react",
  "version": "0.1.0",
  "packageManager": "pnpm@11.10.0",
  "description": "Embeddable React viewer for eNanoMapper/AMBIT substance, composition and study data. React rewrite of the jToxKit Study/Substance kits.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ideaconsult/jtoxkit-react.git"
  },
  "bugs": {
    "url": "https://github.com/ideaconsult/jtoxkit-react/issues"
  },
  "homepage": "https://github.com/ideaconsult/jtoxkit-react#readme",
  "keywords": [
    "ambit",
    "enanomapper",
    "jtoxkit",
    "react",
    "study",
    "substance",
    "viewer"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/jtoxkit-react.js",
  "module": "./dist/jtoxkit-react.js",
  "exports": {
    ".": {
      "import": "./dist/jtoxkit-react.js"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "**/*.css",
    "**/legacyGlobals.js"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.js",
    "preview": "vite preview",
    "prepublishOnly": "pnpm test && pnpm build:lib",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@observablehq/plot": "^0.6.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@observablehq/plot": {
      "optional": true
    }
  },
  "dependencies": {
    "dompurify": "^3.1.7"
  },
  "devDependencies": {
    "@observablehq/plot": "^0.6.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "react": "^18.3.1",
    "react-dom": "^19.2.7",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
}
