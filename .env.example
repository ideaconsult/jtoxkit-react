# Default AMBIT REST base URL used when the host does not pass `apiBase` as a prop.
# Example eNanoMapper / AMBIT instances:
VITE_AMBIT_URL=https://apps.ideaconsult.net/nanoreg1/

# Optional ramanchada-api base for dose-response conversion.
# VITE_RCAPI_URL=https://api.ramanchada.ideaconsult.net/

# Optional: target host for the dev-only /ambit proxy (see vite.config.js).
# VITE_AMBIT_PROXY=https://apps.ideaconsult.net

# Optional: rewrite absolute AMBIT URLs returned by the API onto the same-origin dev proxy.
# VITE_AMBIT_PROXY_FROM=https://apps.ideaconsult.net
# VITE_AMBIT_PROXY_TO=/ambit
